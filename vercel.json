{
  "routes": [
    { "src": "/sitemap.xml", "dest": "/api/sitemap" },
    { "src": "/see/past-papers/([^/]+)/([^/]+)/([^/]+)", "dest": "/api/see-paper?year=$1&province=$2&subject=$3" },
    { "src": "/see/past-papers", "dest": "/see.html?mode=past-papers" },
    { "src": "/see", "dest": "/see.html" }
  ]
}
